<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Şifremi Unuttum | AKEKOS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light d-flex align-items-center justify-content-center min-vh-100">
<div class="container"><div class="row justify-content-center"><div class="col-md-5 col-lg-4">
  <div class="text-center mb-4">
    <i class="bi bi-shield-fill-check display-3 text-warning"></i>
    <h3 class="fw-bold mt-2 mb-0">AKEKOS</h3>
  </div>
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <h5 class="card-title mb-1 fw-semibold">Şifremi Unuttum</h5>
      <p class="text-muted small mb-4">E-posta adresinize sıfırlama bağlantısı göndereceğiz.</p>
      <% if (message) { %>
      <div class="alert alert-success py-2 small"><i class="bi bi-check-circle me-1"></i><%= message %></div>
      <% } %>
      <% if (error) { %>
      <div class="alert alert-danger py-2 small"><i class="bi bi-exclamation-triangle me-1"></i><%= error %></div>
      <% } %>
      <form action="/auth/forgot-password" method="POST">
        <div class="mb-3">
          <label class="form-label small fw-semibold">E-posta</label>
          <input type="email" class="form-control" name="email" required placeholder="ornek@akekos.tr">
        </div>
        <button type="submit" class="btn btn-warning w-100 fw-semibold">Bağlantı Gönder</button>
      </form>
      <div class="text-center mt-3">
        <a href="/auth/login" class="small text-decoration-none"><i class="bi bi-arrow-left me-1"></i>Giriş sayfasına dön</a>
      </div>
    </div>
  </div>
</div></div></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>