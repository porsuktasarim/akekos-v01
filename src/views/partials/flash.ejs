<% if (flash) { %>
  <% if (flash.success && flash.success.length > 0) { %>
    <% flash.success.forEach(msg => { %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i><%= msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% }) %>
  <% } %>
  <% if (flash.error && flash.error.length > 0) { %>
    <% flash.error.forEach(msg => { %>
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i><%= msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% }) %>
  <% } %>
  <% if (flash.info && flash.info.length > 0) { %>
    <% flash.info.forEach(msg => { %>
    <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
      <i class="bi bi-info-circle-fill me-2"></i><%= msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% }) %>
  <% } %>
  <% if (flash.warning && flash.warning.length > 0) { %>
    <% flash.warning.forEach(msg => { %>
    <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
      <i class="bi bi-exclamation-circle-fill me-2"></i><%= msg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% }) %>
  <% } %>
<% } %>
