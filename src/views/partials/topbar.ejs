<header class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4 py-2 shadow-sm">
  <button class="btn btn-outline-secondary btn-sm me-3" id="sidebarToggle" title="Menüyü Aç/Kapat">
    <i class="bi bi-list fs-5"></i>
  </button>

  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="me-auto">
    <ol class="breadcrumb mb-0 small">
      <li class="breadcrumb-item"><a href="/dashboard" class="text-decoration-none"><i class="bi bi-house-fill"></i></a></li>
      <% if (typeof title !== 'undefined') { %>
      <li class="breadcrumb-item active"><%= title %></li>
      <% } %>
    </ol>
  </nav>

  <!-- Sağ taraf -->
  <div class="d-flex align-items-center gap-2">
    <!-- Bildirimler (gelecek fazda) -->
    <button class="btn btn-light btn-sm position-relative" title="Bildirimler">
      <i class="bi bi-bell-fill"></i>
      <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:.55rem;">0</span>
    </button>

    <!-- Profil -->
    <div class="dropdown">
      <button class="btn btn-light btn-sm dropdown-toggle d-flex align-items-center gap-1" data-bs-toggle="dropdown">
        <i class="bi bi-person-circle fs-5"></i>
        <span class="d-none d-md-inline small"><%= user ? (user.firstName + ' ' + user.lastName) : '' %></span>
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow-sm">
        <li><h6 class="dropdown-header"><%= user ? user.email : '' %></h6></li>
        <li><hr class="dropdown-divider"></li>
        <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>Profilim</a></li>
        <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a></li>
      </ul>
    </div>
  </div>
</header>
