<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kullanıcılar | AKEKOS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-light">
<div class="d-flex" id="wrapper">
  <%- include('../../partials/sidebar') %>
  <div id="page-content-wrapper" class="flex-grow-1 d-flex flex-column">
    <%- include('../../partials/topbar') %>
    <main class="container-fluid py-3 px-4 flex-grow-1">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold"><i class="bi bi-person-badge-fill me-2 text-warning"></i>Kullanıcılar</h4>
        <button class="btn btn-warning btn-sm" disabled><i class="bi bi-plus-lg me-1"></i>Yeni Kullanıcı</button>
      </div>
      <div class="alert alert-info border-0 shadow-sm">
        <i class="bi bi-info-circle-fill me-2"></i>
        Kullanıcı yönetimi modülü <strong>Faz 1</strong>'de tamamlanacak.
      </div>
    </main>
    <%- include('../../partials/footer') %>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body></html>