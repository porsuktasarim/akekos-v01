<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Organizasyon Ağacı | AKEKOS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-light">
<div class="d-flex" id="wrapper">
  <%- include('../../partials/sidebar') %>
  <div id="page-content-wrapper" class="flex-grow-1 d-flex flex-column">
    <%- include('../../partials/topbar') %>
    <main class="container-fluid py-3 px-4 flex-grow-1">
      <%- include('../../partials/flash') %>

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold"><i class="bi bi-diagram-2-fill me-2 text-warning"></i>Organizasyon Ağacı</h4>
        <div class="d-flex gap-2">
          <a href="/admin/organizations" class="btn btn-outline-secondary btn-sm"><i class="bi bi-list-ul me-1"></i>Liste Görünüm</a>
          <a href="/admin/organizations/create" class="btn btn-warning btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Ekle</a>
        </div>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <div id="orgTree">
            <!-- JavaScript ile doldurulacak -->
          </div>
        </div>
      </div>

    </main>
    <%- include('../../partials/footer') %>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
<script>
const orgData = <%- JSON.stringify(orgs) %>;

function buildTree(items, parentId) {
  parentId = parentId || null;
  return items.filter(i => String(i.parentId || null) === String(parentId)).map(item => {
    const children = buildTree(items, item._id);
    const typeColors = {merkez:'primary',bolge:'info',il:'success',ilce:'warning',birim:'secondary'};
    const color = typeColors[item.type] || 'secondary';
    let html = `
      <div class="d-flex align-items-center gap-2 py-2 border-bottom">
        <i class="bi bi-building-fill text-${color} flex-shrink-0"></i>
        <div class="flex-grow-1">
          <span class="fw-semibold">${item.name}</span>
          <span class="badge bg-${color}-subtle text-${color} border border-${color}-subtle ms-2 small">${item.type}</span>
          ${!item.isActive ? '<span class="badge bg-danger-subtle text-danger border border-danger-subtle ms-1 small">Pasif</span>' : ''}
        </div>
        <a href="/admin/organizations/${item._id}/edit" class="btn btn-outline-primary btn-sm py-0 px-2"><i class="bi bi-pencil"></i></a>
      </div>
    `;
    if (children.length > 0) {
      html += '<div class="ms-4">' + children + '</div>';
    }
    return html;
  }).join('');
}

document.getElementById('orgTree').innerHTML = buildTree(orgData) || '<p class="text-muted">Henüz organizasyon eklenmemiş.</p>';
</script>
</body>
</html>