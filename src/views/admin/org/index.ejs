<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Organizasyonlar | AKEKOS</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body class="bg-light">
<div class="d-flex" id="wrapper">
  <%- include('../../partials/sidebar') %>
  <div id="page-content-wrapper" class="flex-grow-1 d-flex flex-column">
    <%- include('../../partials/topbar') %>
    <main class="container-fluid py-3 px-4 flex-grow-1">
      <%- include('../../partials/flash') %>

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 fw-bold"><i class="bi bi-diagram-3-fill me-2 text-warning"></i>Organizasyonlar</h4>
        <div class="d-flex gap-2">
          <a href="/admin/organizations/tree" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-diagram-2 me-1"></i>Ağaç Görünüm
          </a>
          <a href="/admin/organizations/create" class="btn btn-warning btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Yeni Organizasyon
          </a>
        </div>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <table id="orgsTable" class="table table-hover table-sm align-middle w-100">
            <thead class="table-light">
              <tr>
                <th>Organizasyon Adı</th>
                <th>Tür</th>
                <th>Üst Org.</th>
                <th>Seviye</th>
                <th>Durum</th>
                <th>İşlemler</th>
              </tr>
            </thead>
            <tbody>
              <% orgs.forEach(org => { %>
              <tr>
                <td>
                  <% for(let i=0; i<org.level; i++) { %><span class="ms-3"></span><% } %>
                  <% if(org.level > 0) { %><i class="bi bi-arrow-return-right text-muted me-1 small"></i><% } %>
                  <strong><%= org.name %></strong>
                  <small class="text-muted ms-1">/<%= org.slug %></small>
                </td>
                <td>
                  <% const typeColors = {merkez:'primary',bolge:'info',il:'success',ilce:'warning',birim:'secondary'}; %>
                  <span class="badge bg-<%= typeColors[org.type] || 'secondary' %>-subtle text-<%= typeColors[org.type] || 'secondary' %> border border-<%= typeColors[org.type] || 'secondary' %>-subtle">
                    <%= org.type %>
                  </span>
                </td>
                <td class="text-muted small"><%= org.parentId ? org.parentId.name : '-' %></td>
                <td><span class="badge bg-light text-dark border"><%= org.level %></span></td>
                <td>
                  <div class="form-check form-switch mb-0">
                    <input class="form-check-input status-toggle" type="checkbox" 
                      data-id="<%= org._id %>" <%= org.isActive ? 'checked' : '' %>
                      title="<%= org.isActive ? 'Pasif yap' : 'Aktif yap' %>">
                  </div>
                </td>
                <td>
                  <a href="/admin/organizations/<%= org._id %>/edit" class="btn btn-outline-primary btn-sm py-0 px-2">
                    <i class="bi bi-pencil-fill"></i>
                  </a>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
    <%- include('../../partials/footer') %>
  </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="/js/main.js"></script>
<script>
$(document).ready(function() {
  $('#orgsTable').DataTable({
    language: { url: 'https://cdn.datatables.net/plug-ins/1.13.8/i18n/tr.json' },
    pageLength: 25,
    responsive: true,
    columnDefs: [{ orderable: false, targets: [4,5] }]
  });

  // Status toggle
  $(document).on('change', '.status-toggle', function() {
    const id = $(this).data('id');
    const self = this;
    fetch('/admin/organizations/' + id + '/toggle', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' }
    }).then(r => r.json()).then(d => {
      if (d.success) {
        AKEKOS.toast(d.message, 'success');
      } else {
        $(self).prop('checked', !$(self).prop('checked'));
        AKEKOS.toast(d.message || 'Hata oluştu.', 'danger');
      }
    }).catch(() => {
      $(self).prop('checked', !$(self).prop('checked'));
      AKEKOS.toast('Bağlantı hatası.', 'danger');
    });
  });
});
</script>
</body>
</html>