# =============================================
# AKEKOS - Ortam Değişkenleri Örneği
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# =============================================

# Uygulama
NODE_ENV=development
PORT=3000
APP_NAME=AKEKOS
APP_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://mongo:27017/akekos
MONGODB_URI_TEST=mongodb://mongo:27017/akekos_test

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_refresh_secret_change_this_too
JWT_REFRESH_EXPIRE=7d

# Session
SESSION_SECRET=your_session_secret_change_this
SESSION_MAX_AGE=604800000

# E-posta (Şifre sıfırlama için)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@akekos.local
SMTP_PASS=your_smtp_password
SMTP_FROM=AKEKOS <noreply@akekos.local>

# Güvenlik
BCRYPT_ROUNDS=12
LOGIN_ATTEMPT_LIMIT=5
LOGIN_LOCKOUT_TIME=900000

# Dosya Yükleme
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Log
LOG_LEVEL=info
LOG_DIR=./logs
